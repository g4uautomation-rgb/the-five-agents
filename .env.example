# ============================================================
#  .env.example — תבנית משתני סביבה לצוות חמשת הסוכנים
# ------------------------------------------------------------
#  העתק קובץ זה ל-.env ומלא את הערכים האמיתיים:
#      cp .env.example .env
#  הקובץ .env אינו נכנס ל-git (מוגדר ב-.gitignore).
#  אל תכניס סודות אמיתיים לקובץ הזה.
# ============================================================

# --- Anthropic / Claude (הרצת הסוכנים) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Airtable (חן / נתונים) ---
AIRTABLE_API_KEY=your-airtable-api-key-here
AIRTABLE_BASE_ID=your-airtable-base-id-here

# --- יצירת תמונות (יובל / מעצב התמונות) — OpenAI Images API, מודל gpt-image-2 ---
OPENAI_API_KEY=your-openai-api-key-here

# --- מחקר / חיפוש (חן / החוקרת) ---
SEARCH_API_KEY=your-search-api-key-here
